<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="430.0" prefWidth="420.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.CreateEventView">
    <children>
        <Label layoutX="30.0" layoutY="25.0" text="Create Event" />

        <Label layoutX="30.0" layoutY="65.0" text="Name" />
        <TextField fx:id="nameField" layoutX="150.0" layoutY="60.0" />

        <Label layoutX="30.0" layoutY="105.0" text="Description" />
        <TextArea fx:id="descriptionField" layoutX="150.0" layoutY="100.0" prefHeight="60.0" prefWidth="180.0" />

        <Label layoutX="30.0" layoutY="177.0" text="Date" />
        <TextField fx:id="dateField" layoutX="150.0" layoutY="172.0" />

        <Label layoutX="30.0" layoutY="207.0" text="Time" />
        <TextField fx:id="timeField" layoutX="150.0" layoutY="202.0" />

        <Label layoutX="30.0" layoutY="266.0" text="Total Tickets" />
        <TextField fx:id="totalTicketsField" layoutX="150.0" layoutY="261.0" />

        <Label layoutX="30.0" layoutY="328.0" text="Image URL" />
        <TextField fx:id="imageURLField" layoutX="150.0" layoutY="323.0" />

        <Label layoutX="30.0" layoutY="237.0" text="Location" />
        <TextField fx:id="locationField" layoutX="150.0" layoutY="232.0" />

        <Label layoutX="30.0" layoutY="298.0" text="Ticket price" />
        <TextField fx:id="ticketPriceField" layoutX="150.0" layoutY="293.0" />

        <Label layoutX="30.0" layoutY="361.0" text="Capacity" />
        <TextField fx:id="capacityField" layoutX="150.0" layoutY="356.0" />

        <Button layoutX="150.0" layoutY="390.0" mnemonicParsing="false" onAction="#onCreateEvent" text="Create Event" />
    </children>
</AnchorPane>
