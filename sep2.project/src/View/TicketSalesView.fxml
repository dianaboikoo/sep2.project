<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="320.0" prefWidth="420.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="View.TicketSalesView">
    <children>
        <Label layoutX="30.0" layoutY="25.0"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"
               text="Ticket Sales Report" />

        <Label layoutX="30.0" layoutY="75.0" text="Event name:" />
        <Label fx:id="eventNameLabel" layoutX="190.0" layoutY="75.0" />

        <Label layoutX="30.0" layoutY="110.0" text="Total tickets defined:" />
        <Label fx:id="totalTicketsLabel" layoutX="190.0" layoutY="110.0" />

        <Label layoutX="30.0" layoutY="145.0" text="Tickets sold:" />
        <Label fx:id="ticketsSoldLabel" layoutX="190.0" layoutY="145.0" />

        <Label layoutX="30.0" layoutY="180.0" text="Tickets remaining:" />
        <Label fx:id="ticketsRemainingLabel" layoutX="190.0" layoutY="180.0" />

        <Label layoutX="30.0" layoutY="215.0" text="Total revenue (DKK):" />
        <Label fx:id="totalRevenueLabel" layoutX="190.0" layoutY="215.0" />

        <Button layoutX="175.0" layoutY="265.0"
                mnemonicParsing="false"
                onAction="#onClose"
                text="Close" />
    </children>
</AnchorPane>