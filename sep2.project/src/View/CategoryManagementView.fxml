<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.CategoryManagementView">
    <children>

        <Label layoutX="30.0" layoutY="20.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Manage Categories" />

        <!-- ===== Add New Category form ===== -->
        <Label layoutX="30.0" layoutY="60.0" style="-fx-font-weight: bold;" text="Add New Category" />

        <Label layoutX="30.0" layoutY="95.0" text="Name *" />
        <TextField fx:id="nameField" layoutX="120.0" layoutY="90.0" prefWidth="350.0" promptText="required" />
        <Label fx:id="nameError" layoutX="120.0" layoutY="115.0" textFill="red" />

        <Label layoutX="30.0" layoutY="145.0" text="Description" />
        <TextArea fx:id="descriptionField" layoutX="120.0" layoutY="140.0" prefHeight="60.0" prefWidth="350.0" promptText="(optional)" />
        <Label fx:id="descriptionError" layoutX="120.0" layoutY="200.0" textFill="red" />

        <Button fx:id="addButton" layoutX="120.0" layoutY="225.0" mnemonicParsing="false" onAction="#onAddCategory" text="Add Category" />

        <!-- ===== Existing categories table ===== -->
        <Label layoutX="30.0" layoutY="280.0" style="-fx-font-weight: bold;" text="Existing Categories" />

        <TableView fx:id="categoryTable" layoutX="30.0" layoutY="305.0" prefHeight="220.0" prefWidth="640.0">
            <columns>
                <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Name" />
                <TableColumn fx:id="descriptionColumn" prefWidth="280.0" text="Description" />
                <TableColumn fx:id="actionsColumn" prefWidth="158.0" text="Actions" />
            </columns>
        </TableView>

        <!-- ===== Status / toast area ===== -->
        <Label fx:id="statusMessage" layoutX="30.0" layoutY="540.0" prefWidth="640.0" />

    </children>
</AnchorPane>
