<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="280.0" prefWidth="360.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="View.PurchaseTicketView">
    <children>

        <Label layoutX="30.0" layoutY="20.0"
               style="-fx-font-size: 16px; -fx-font-weight: bold;"
               text="Buy Ticket" />

        <Label layoutX="30.0"  layoutY="65.0"  text="Event" />
        <Label fx:id="eventNameLabel"
               layoutX="150.0" layoutY="65.0" prefWidth="180.0" wrapText="true" />

        <Label layoutX="30.0"  layoutY="95.0"  text="Price per ticket" />
        <Label fx:id="ticketPriceLabel"
               layoutX="150.0" layoutY="95.0" />

        <Label layoutX="30.0"  layoutY="125.0" text="Available" />
        <Label fx:id="availableLabel"
               layoutX="150.0" layoutY="125.0" />

        <Label layoutX="30.0"  layoutY="160.0" text="Quantity" />
        <TextField fx:id="quantityField"
                   layoutX="150.0" layoutY="155.0"
                   prefWidth="80.0" promptText="1" />

        <Label fx:id="errorLabel"
               layoutX="30.0" layoutY="190.0" prefWidth="300.0"
               textFill="red" visible="false" managed="false" wrapText="true" />

        <Label fx:id="successLabel"
               layoutX="30.0" layoutY="190.0" prefWidth="300.0"
               textFill="green" visible="false" managed="false" wrapText="true" />

        <Button layoutX="150.0" layoutY="235.0"
                text="Confirm Purchase"
                mnemonicParsing="false"
                onAction="#onConfirm" />

        <Button layoutX="275.0" layoutY="235.0"
                text="Cancel"
                mnemonicParsing="false"
                onAction="#onCancel" />

    </children>
</AnchorPane>
