<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="300.0" prefWidth="380.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="View.LoginView">
    <children>

        <Label layoutX="140.0" layoutY="30.0" text="Login"
               style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <Label layoutX="40.0" layoutY="90.0" text="Email:" />
        <TextField fx:id="emailField"
                   layoutX="40.0" layoutY="110.0"
                   prefWidth="300.0"
                   promptText="Enter your email" />

        <Label layoutX="40.0" layoutY="150.0" text="Password:" />
        <PasswordField fx:id="passwordField"
                       layoutX="40.0" layoutY="170.0"
                       prefWidth="300.0"
                       promptText="Enter your password" />

        <Button layoutX="40.0" layoutY="220.0"
                prefWidth="300.0"
                text="Login"
                mnemonicParsing="false"
                onAction="#onLogin"
                style="-fx-font-size: 14px;" />

        <Label fx:id="errorLabel"
               layoutX="40.0" layoutY="260.0"
               prefWidth="300.0"
               text=""
               style="-fx-text-fill: red;" />

    </children>
</AnchorPane>
