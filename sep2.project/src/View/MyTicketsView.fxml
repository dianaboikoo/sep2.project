<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="420.0" prefWidth="560.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="View.MyTicketsView">
    <children>

        <!-- Title -->
        <Label layoutX="30.0" layoutY="20.0"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"
               text="My Tickets" />

        <!-- Tickets table -->
        <TableView fx:id="ticketsTable"
                   layoutX="30.0" layoutY="60.0"
                   prefHeight="290.0" prefWidth="500.0">
            <columns>
                <TableColumn fx:id="ticketIdColumn"     prefWidth="130.0" text="Ticket ID" />
                <TableColumn fx:id="eventNameColumn"    prefWidth="140.0" text="Event Name" />
                <TableColumn fx:id="purchaseDateColumn" prefWidth="120.0" text="Purchase Date" />
                <TableColumn fx:id="quantityColumn"     prefWidth="55.0"  text="Qty" />
                <TableColumn fx:id="statusColumn"       prefWidth="55.0"  text="Status" />
            </columns>
        </TableView>

        <!-- Empty-state label (hidden until needed) -->
        <Label fx:id="noTicketsLabel"
               layoutX="30.0" layoutY="200.0"
               text="You have no purchased tickets."
               visible="false" />

        <!-- Close button -->
        <Button layoutX="470.0" layoutY="370.0"
                mnemonicParsing="false"
                onAction="#onClose"
                text="Close" />

    </children>
</AnchorPane>
