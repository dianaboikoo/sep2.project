<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="660.0" prefWidth="860.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.EventsListView">
    <children>

        <Label layoutX="30.0" layoutY="20.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Upcoming Events" />

        <!-- ============== Filter bar ============== -->
        <VBox layoutX="30.0" layoutY="55.0" prefWidth="800.0" spacing="6.0">
            <children>
                <Label style="-fx-font-weight: bold;" text="Filters" />

                <HBox alignment="BOTTOM_LEFT" spacing="12.0">
                    <children>

                        <VBox spacing="4.0">
                            <children>
                                <Label text="Category" />
                                <ComboBox fx:id="categoryFilter" prefWidth="160.0" promptText="All categories" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label text="City" />
                                <ComboBox fx:id="cityFilter" prefWidth="160.0" promptText="All cities" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label text="From date" />
                                <DatePicker fx:id="fromDatePicker" prefWidth="140.0" />
                            </children>
                        </VBox>

                        <VBox spacing="4.0">
                            <children>
                                <Label text="To date" />
                                <DatePicker fx:id="toDatePicker" prefWidth="140.0" />
                            </children>
                        </VBox>

                        <HBox alignment="BOTTOM_CENTER" spacing="6.0">
                            <children>
                                <Button fx:id="applyFiltersButton" mnemonicParsing="false" onAction="#onApplyFilters" text="Apply" />
                                <Button fx:id="clearFiltersButton" mnemonicParsing="false" onAction="#onClearFilters" text="Clear" />
                            </children>
                        </HBox>

                    </children>
                </HBox>

                <!-- Single shared error label (hidden by default) -->
                <Label fx:id="filterError" managed="false" textFill="red" visible="false" />
            </children>
        </VBox>

        <!-- ============== Events table ============== -->
        <TableView fx:id="eventsTable" layoutX="30.0" layoutY="170.0" prefHeight="380.0" prefWidth="800.0">
            <columns>
                <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Event" />
                <TableColumn fx:id="dateTimeColumn" prefWidth="150.0" text="Date &amp; Time" />
                <TableColumn fx:id="venueColumn" prefWidth="140.0" text="Venue" />
                <TableColumn fx:id="categoryColumn" prefWidth="110.0" text="Category" />
                <TableColumn fx:id="cityColumn" prefWidth="100.0" text="City" />
                <TableColumn fx:id="availableTicketsColumn" prefWidth="95.0" text="Tickets Left" />
            </columns>
        </TableView>

        <Label fx:id="noEventsLabel" layoutX="30.0" layoutY="350.0" text="No upcoming events match the current filters." visible="false" />

        <!-- Bottom row: View Details (always visible) + Admin buttons -->
        <HBox layoutX="30.0" layoutY="565.0" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#onViewDetails" text="View Details" />

            <Button fx:id="createEventButton" managed="false" mnemonicParsing="false" onAction="#onCreateEvent" text="Create Event" visible="false" />

            <Button fx:id="manageCategoriesButton" managed="false" mnemonicParsing="false" onAction="#onManageCategories" text="Manage Categories" visible="false" />
        </HBox>

    </children>
</AnchorPane>
