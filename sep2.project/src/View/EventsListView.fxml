<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="520.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="View.EventsListView">
    <children>

        <Label layoutX="30.0" layoutY="20.0" text="Upcoming Events"
               style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <TableView fx:id="eventsTable"
                   layoutX="30.0" layoutY="55.0"
                   prefWidth="800.0" prefHeight="380.0">
            <columns>
                <TableColumn fx:id="nameColumn"         text="Event"             prefWidth="200.0" />
                <TableColumn fx:id="dateTimeColumn"     text="Date &amp; Time"   prefWidth="150.0" />
                <TableColumn fx:id="venueColumn"        text="Venue"             prefWidth="140.0" />
                <TableColumn fx:id="categoryColumn"     text="Category"          prefWidth="110.0" />
                <TableColumn fx:id="cityColumn"         text="City"              prefWidth="100.0" />
                <TableColumn fx:id="availableTicketsColumn" text="Tickets Left"  prefWidth="95.0"  />
            </columns>
        </TableView>

        <Label fx:id="noEventsLabel"
               layoutX="30.0" layoutY="250.0"
               text="No upcoming events at the moment."
               visible="false" />

        <Button layoutX="30.0" layoutY="455.0"
                text="View Details"
                mnemonicParsing="false"
                onAction="#onViewDetails" />

    </children>
</AnchorPane>
